{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LIMEN OS",
  "version": "0.1.0",
  "identifier": "os.limen.shell",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LIMEN OS",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "enableGTKAppId": true,
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
