# -----------------------------------------------------------------------------
# Runtime (optional)
# -----------------------------------------------------------------------------
# Browser-side YouTube Data API fallback (web app builds only).
VITE_YOUTUBE_API_KEY=

# Optional HTTP backend for YouTube search aggregation/proxy.
VITE_YOUTUBE_SEARCH_BACKEND=
# Example:
# VITE_YOUTUBE_SEARCH_BACKEND=https://search.waldiez.io/youtube/search

# -----------------------------------------------------------------------------
# Content pipeline (optional, CI/scripts for latest-auto.wid generation)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LATEST_WID_YT_QUERY="latest news world"
LATEST_WID_YT_CHANNEL_IDS=
LATEST_WID_MIN_DURATION_SECONDS=180
LATEST_WID_BLOCKED_TERMS=shorts,trailer,teaser

# -----------------------------------------------------------------------------
# Apple signing / release (optional, only for signed macOS + MAS builds)
# -----------------------------------------------------------------------------
APPLE_CERTIFICATE=
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
APPLE_MAS_CERTIFICATE=
APPLE_MAS_CERTIFICATE_PASSWORD=
APPLE_MAS_SIGNING_IDENTITY=
