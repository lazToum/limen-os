# Copy to .ec2.env and fill in — never commit .ec2.env
# cp .ec2.env.example .ec2.env

EC2_HOST=limen@io.what-if.io      # service account; falls back to admin@/ubuntu@ on first push
EC2_KEY=~/.ssh/your-key.pem        # omit if key is in ssh-agent

DOMAIN_NAME=io.what-if.io
CERTBOT_EMAIL=you@io.what-if.io
SKIP_CERTBOT=0                      # set 1 for testing / before DNS is ready
SKIP_DISPLAY=0                      # set 1 for pure headless web (no Xvfb/kiosk/VNC)

REMOTE_DIR=/opt/limen
LIMEN_USER=limen   # service account that owns REMOTE_DIR (created by setup.sh)

# Simulation services — sinergym / smartcities profiles
# Run `make vendor LIMEN_CODE_DIR=/path/to/limen/code/limen` locally to
# populate services/*/vendor/ dirs, then `make push` to build + deploy the images.
# No runtime env vars needed — sources are baked into the Docker images.

# Runtime versions (defaults match CLAUDE.md / EC2 snapshot 2026-03-12)
NVM_VERSION=v0.40.4
NODE_VERSION=v24.14.0
FLUTTER_VERSION=3.41.4
GO_VERSION=1.24.4
YARN_VERSION=4.13.0
