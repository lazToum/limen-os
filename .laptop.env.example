# Limen OS → Laptop push config
# cp .laptop.env.example .laptop.env   (never commit .laptop.env)

LAPTOP_HOST=tam@192.168.1.50     # user@ip or user@hostname of your laptop
LAPTOP_KEY=                       # path to SSH private key (leave empty if using ssh-agent)
LAPTOP_DIR=~/limen              # destination directory on the laptop

COMMIT_MSG=                       # auto-generated if empty: "chore: sync from limen-os @ <timestamp>"
GIT_PUSH=0                        # set 1 to also run `git push` on the laptop after commit
GIT_REMOTE=origin                 # remote name to push to (if GIT_PUSH=1)
GIT_BRANCH=                       # branch to push to (default: laptop repo's current branch)

LAPTOP_CMD=                       # optional command to run on laptop after sync
                                  # e.g. "bun install && make packages-build"
                                  # or   "git push origin main"
                                  # or   "make shell-dev"  (opens dev server on laptop)
