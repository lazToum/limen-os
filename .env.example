# LIMEN OS — Environment Variables
# Copy to .env and fill in your values.
# Many values are inherited from /opt/limen/.env on startup.

# cspell: disable

# ─── Web Search (Browser app — priority order) ───────────
TAVILY_API_KEY=            # Tavily — best results, free tier at tavily.com
GOOGLE_SEARCH_API_KEY=     # Google Custom Search API key
GOOGLE_SEARCH_CX=          # Google Custom Search Engine ID (cx)
BRAVE_SEARCH_API_KEY=      # Brave Search API — search.brave.com/app/keys
# No key needed: DuckDuckGo HTML scraping is the automatic fallback

# ─── AI Models ───────────────────────────────────────────
ANTHROPIC_API_KEY=         # Claude — primary AI
OPENAI_API_KEY=            # GPT-4o — fallback
GOOGLE_GEMINI_API_KEY=     # Gemini 2.0 Flash — fallback
DEEPSEEK_API_KEY=          # Deepseek V3/R1 — cheap fallback
GROQ_API_KEY=              # Groq Llama — ultra-fast fallback
MISTRAL_API_KEY=           # Mistral — optional

# ─── Voice ───────────────────────────────────────────────
LIMEN_WAKE_WORD=hey_limen
LIMEN_STT_MODE=hybrid        # whisper | webspeech | hybrid
LIMEN_TTS_MODE=kokoro        # kokoro | piper | browser
LIMEN_VOICE_LANG=en-US

# Whisper STT server — docker/dev-services.yml runs faster-whisper-server on 8083.
# VITE_WHISPER_URL enables MediaRecorder+Whisper in the browser (Tauri-compatible,
# no WebSpeech API dependency). Leave blank to fall back to WebSpeech.
WHISPER_PORT=8083
WHISPER_BASE_URL=http://localhost:8083   # used by limen-voiced daemon
VITE_WHISPER_URL=http://localhost:8083   # used by shell browser voice client

# ─── AgentFlow ───────────────────────────────────────────
AF_PORT=8889           # monitor server (WS + dashboard) — /af/
AF_API_PORT=8890       # full actor REST API              — /af/api/
AF_LLM=anthropic       # anthropic | openai | ollama | nim
AF_API_KEY=            # optional REST auth key (X-API-Key header)

# ─── Simulation services (sinergym / smartcities profiles) ──
# Sources are baked into Docker images via vendor/ dirs.
# Run once: make vendor LIMEN_CODE_DIR=/path/to/limen/code/limen
# Then rebuild: make dev-sim-up

# ─── Home Assistant ──────────────────────────────────────
# HA_ORIGIN controls where serve.ts proxies /ha/ requests.
# Default: Docker container at 127.0.0.1:8123
# For local LAN HA (Vagrant or BeagleBone on same network):
#   HA_ORIGIN=http://192.168.1.50:8123
# For EC2 → LAN HA via reverse tunnel (scripts/ha-tunnel.sh):
#   leave as default — tunnel binds 127.0.0.1:8123 on the server
HA_ORIGIN=http://127.0.0.1:8123
HA_PORT=8123

# ─── Shell embedded-app service URLs ─────────────────────
# Override defaults via window.__LIMEN_SERVICES__ (nginx injection) or these vars.
VITE_HA_URL=                             # e.g. http://homeassistant.local:8123
VITE_CODE_URL=http://localhost:8080
VITE_JUPYTER_URL=http://localhost:8888
VITE_PORTAINER_URL=http://localhost:9000
VITE_GRAFANA_URL=http://localhost:3000
VITE_NODERED_URL=http://localhost:1880
VITE_SINERGYM_URL=http://localhost:8090   # sinergym profile
VITE_SMARTCITIES_URL=http://localhost:8091 # smartcities profile

# ─── Shell ───────────────────────────────────────────────
LIMEN_DEFAULT_SCENE=greeter  # greeter | home | ambient
LIMEN_GPU_MODE=auto          # auto | webgpu | webgl2
LIMEN_THEME=dark             # dark | light | auto
LIMEN_INACTIVITY_SECS=300    # Seconds until ambient scene

# ─── Core Daemon ─────────────────────────────────────────
LIMEN_SOCKET=/run/limen/core.sock
LIMEN_LOG=limen_core=info,limen_ai=debug

# ─── Mobile Bridge ───────────────────────────────────────
LIMEN_MOBILE_PORT=8766
LIMEN_WEBRTC_STUN=stun:stun.l.google.com:19302

# ─── Flutter Web companion ───────────────────────────────
# In dev: run `make mobile-web-server` (serves on :4174).
# In prod: copy flutter build output to dist/mobile/ alongside the shell.
VITE_FLUTTER_URL=           # blank = use /mobile/ proxy; set to http://localhost:4174 for direct
FLUTTER_WEB_PORT=4174       # port the Flutter web dev server listens on

# ─── Auth (session-cookie login, replaces nginx basic-auth) ──────────────────
LIMEN_AUTH_USER=limen  # login username (default: limen)
LIMEN_AUTH_PASS=         # login password — MUST be set in production!

# ─── Development ─────────────────────────────────────────
VITE_DEV_SERVER_PORT=1420
GDK_BACKEND=x11            # Force X11 backend in container (no native Wayland)
